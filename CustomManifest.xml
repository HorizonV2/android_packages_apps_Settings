<manifest xmlns:android="http://schemas.android.com/apk/res/android"
        package="com.android.settings">
    <application>

    <!-- HorizonLab additions -->
        <activity
            android:name="com.android.settings.Settings$HorizonlabSettingsActivity"
            android:exported="true"
            android:icon="@drawable/ic_homepage_horizon"
            android:label="@string/horizon_dashboard_title"
            android:parentActivityName="com.android.settings" >
            <intent-filter>
                <action android:name="com.android.settings.action.SETTINGS" />
            </intent-filter>

            <meta-data
                android:name="com.android.settings.FRAGMENT_CLASS"
                android:value="com.horizon.lab.HorizonDashboard" />
            <meta-data
                android:name="com.android.settings.summary"
                android:resource="@string/build_tweaks_summary_title" />
        </activity>
        <activity
            android:name="com.android.settings.Settings$AboutTeamActivity"
            android:exported="true"
            android:label="@string/hz_about_title" >
            <intent-filter android:priority="1" >
                <action android:name="com.horizon.lab.category.AboutTeamFragment" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="71" >
                <action android:name="android.intent.action.MAIN" />
                <category android:name="com.android.settings.SHORTCUT" />
            </intent-filter>

            <meta-data
                android:name="com.android.settings.FRAGMENT_CLASS"
                android:value="com.horizon.lab.category.AboutTeamFragment" />
            <meta-data
                android:name="com.android.settings.HIGHLIGHT_MENU_KEY"
                android:value="@string/menu_key_about_device" />
            <meta-data
                android:name="com.android.settings.PRIMARY_PROFILE_CONTROLLED"
                android:value="true" />
        </activity>
        <activity
            android:name="com.android.settings.Settings$QuickSettingsActivity"
            android:exported="true"
            android:label="@string/category_quicksettings_title" >
            <intent-filter android:priority="1" >
                <action android:name="com.horizon.lab.category.QuickSettings" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="71" >
                <action android:name="android.intent.action.MAIN" />
                <category android:name="com.android.settings.SHORTCUT" />
            </intent-filter>

            <meta-data
                android:name="com.android.settings.FRAGMENT_CLASS"
                android:value="com.horizon.lab.category.QuickSettings" />
            <meta-data
                android:name="com.android.settings.HIGHLIGHT_MENU_KEY"
                android:value="@string/menu_key_about_device" />
            <meta-data
                android:name="com.android.settings.PRIMARY_PROFILE_CONTROLLED"
                android:value="true" />
        </activity>
        <activity
            android:name="com.android.settings.Settings$StatusbarActivity"
            android:exported="true"
            android:label="@string/category_statusbar_title" >
            <intent-filter android:priority="1" >
                <action android:name="com.horizon.lab.category.Statusbar" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter android:priority="71" >
                <action android:name="android.intent.action.MAIN" />

                <category android:name="com.android.settings.SHORTCUT" />
            </intent-filter>

            <meta-data
                android:name="com.android.settings.FRAGMENT_CLASS"
                android:value="com.horizon.lab.category.Statusbar" />
            <meta-data
                android:name="com.android.settings.HIGHLIGHT_MENU_KEY"
                android:value="@string/menu_key_about_device" />
            <meta-data
                android:name="com.android.settings.PRIMARY_PROFILE_CONTROLLED"
                android:value="true" />
        </activity>

    </application>
</manifest>